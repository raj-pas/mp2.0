DJANGO_SECRET_KEY=mp20-local-dev-only
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DATABASE_URL=postgres://mp20:mp20@localhost:5432/mp20
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Required for real-data upload/review. Must be outside this git repository.
MP20_SECURE_DATA_ROOT=/absolute/path/outside/mp2.0-secure-data
MP20_ENGINE_ENABLED=1
MP20_REVIEW_TEAM_SLUG=steadyhand
MP20_WORKER_NAME=local-worker
MP20_WORKER_STALE_SECONDS=60
MP20_OCR_MAX_PAGES=12
MP20_TEXT_EXTRACTION_MAX_CHARS=24000

# Optional local login bootstrap. Keep real credentials out of git.
MP20_LOCAL_ADMIN_EMAIL=advisor@example.com
MP20_LOCAL_ADMIN_PASSWORD=change-this-local-password
MP20_LOCAL_ANALYST_EMAIL=analyst@example.com
MP20_LOCAL_ANALYST_PASSWORD=change-this-local-password

# Required for real-derived extraction. Use an IAM principal with Bedrock access.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ca-central-1
BEDROCK_MODEL=global.anthropic.claude-sonnet-4-6

# Optional local real-bundle browser regression. Must point outside the repo.
MP20_REAL_BUNDLE_ROOT=
PLAYWRIGHT_OUTPUT_DIR=
